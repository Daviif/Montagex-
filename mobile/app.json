{
  "expo": {
    "name": "Montagex",
    "slug": "montagex-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.montagex.mobile",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Usamos sua localizacao para sugerir a proxima rota e melhorar o atendimento."
      }
    },
    "android": {
      "package": "com.montagex.mobile",
      "permissions": [
        "CAMERA",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "extra": {
      "apiUrl": "http://192.168.2.9:3000/api"
    },
    "plugins": [
      "expo-secure-store",
      "expo-font"
    ]
  }
}
